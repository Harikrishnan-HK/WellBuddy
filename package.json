{
  "name": "wellbuddy",
  "version": "1.0.0",
  "description": "Local-first Personal Wellness PWA",
  "scripts": {
    "server": "node backend/server.js",
    "dev": "cd frontend && npm run dev",
    "prestart": "lsof -ti:3001 | xargs kill -9 2>/dev/null; lsof -ti:5173 | xargs kill -9 2>/dev/null; true",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "cd frontend && npm install && npm run build",
    "serve": "NODE_ENV=production node backend/server.js",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
